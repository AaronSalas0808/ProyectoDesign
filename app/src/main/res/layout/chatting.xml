<!--
╔══════════════════════════════════════════════════════════════════════════════╗
║  activity_chat_detail.xml                                                    ║
║  Pantalla de conversación individual en BookLoop.                            ║
║                                                                              ║
║  ESTRUCTURA:                                                                 ║
║  ┌─────────────────────────────┐                                             ║
║  │  ←  [👤] Julian Reed   ⋮   │  ← Toolbar: back + avatar + nombre + menú   ║
║  │       ACTIVE NOW            │                                             ║
║  ├─────────────────────────────┤                                             ║
║  │           TODAY             │  ← Separador de fecha (centrado)            ║
║  │                             │                                             ║
║  │  ┌──────────────────────┐   │  ← Burbuja del otro usuario (izquierda)    ║
║  │  │ Hey! I'm outside...  │   │                                             ║
║  │  └──────────────────────┘   │                                             ║
║  │  10:42 AM                   │  ← Timestamp bajo la burbuja                ║
║  │                             │                                             ║
║  │      ┌──────────────────┐   │  ← Burbuja propia (derecha, roja)          ║
║  │      │ Yes! Just fini...│   │                                             ║
║  │      └──────────────────┘   │                                             ║
║  │                   10:45 AM  │                                             ║
║  │  ... más mensajes           │                                             ║
║  ├─────────────────────────────┤                                             ║
║  │  📎  Message Julian...  [▶] │  ← Input de mensaje + botón enviar          ║
║  └─────────────────────────────┘                                             ║
║                                                                              ║
║  USO:                                                                        ║
║  - Lanzar desde MessagesFragment al hacer click en un chat                   ║
║  - Intent extras: EXTRA_CONTACT_NAME, EXTRA_CONTACT_AVATAR_URL               ║
║  - RecyclerView con ChatMessageAdapter.kt usando:                            ║
║      item_message_received.xml  (burbuja izquierda, gris claro)             ║
║      item_message_sent.xml      (burbuja derecha, rojo)                     ║
╚══════════════════════════════════════════════════════════════════════════════╝
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5EE">

    <!-- ─────────────────────────────────────── -->
    <!-- SECCIÓN 1: TOOLBAR                      -->
    <!-- ─────────────────────────────────────── -->
    <include layout="@layout/include_chat_toolbar" />

    <!-- ─────────────────────────────────────── -->
    <!-- SECCIÓN 2: LISTA DE MENSAJES            -->
    <!-- ─────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- ─────────────────────────────────────── -->
    <!-- SECCIÓN 3: INPUT DE MENSAJE             -->
    <!-- ─────────────────────────────────────── -->
    <include layout="@layout/include_chat_input" />

</LinearLayout>