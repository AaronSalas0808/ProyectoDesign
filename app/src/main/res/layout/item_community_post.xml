<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════════════ -->
        <!-- SECCIÓN 1: Avatar + Nombre + Tiempo    -->
        <!-- ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/ivPostAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:background="@drawable/book_card_profile_image_bg"
                android:clipToOutline="true"
                android:contentDescription="@string/owner_profile_description" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvPostAuthorName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Melany Arrieta"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:id="@+id/tvPostTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="2 hours ago"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════════ -->
        <!-- SECCIÓN 2: Texto del post              -->
        <!-- ══════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvPostContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingBottom="14dp"
            android:text="Just finished reading this amazing book. The atmosphere is just unmatched! Has anyone else found themselves romanticizing their library hours because of this book?"
            android:textSize="14sp"
            android:textColor="#2C2C2C"
            android:lineSpacingExtra="3dp" />

        <!-- ══════════════════════════════════════ -->
        <!-- SECCIÓN 3: Imagen adjunta (opcional)   -->
        <!-- GONE por defecto; el adapter la muestra-->
        <!-- cuando el post tiene imagen            -->
        <!-- ══════════════════════════════════════ -->
        <ImageView
            android:id="@+id/ivPostImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="14dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_post_image"
            android:clipToOutline="true"
            android:visibility="gone"
            android:contentDescription="@string/post_image_description" />

        <!-- Divisor sutil -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:background="#F0F0F0" />

        <!-- ══════════════════════════════════════ -->
        <!-- SECCIÓN 4: Likes y Comentarios         -->
        <!-- ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <!-- Corazón + contador de likes -->
            <ImageView
                android:id="@+id/ivLikeIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_heart" />

            <!-- Espacio entre grupos -->

            <!-- Burbuja de comentario + contador -->

            <TextView
                android:id="@+id/tvLikeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="24"
                android:textColor="#888888"
                android:textSize="13sp" />

            <ImageView
                android:id="@+id/ivCommentIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_comment" />

            <TextView
                android:id="@+id/tvCommentCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="8"
                android:textColor="#888888"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
