<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    tools:context=".ui.discovery.DiscoveryFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivMenuBurger"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_menu"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/app_name_bookloop"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#C0392B"
            android:fontFamily="serif" />

        <ImageView
            android:id="@+id/ivHeaderProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:background="@drawable/book_card_profile_image_bg"
            android:clipToOutline="true"
            android:contentDescription="@null" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_search_field"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:paddingHorizontal="14dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            android:contentDescription="@null" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:hint="Find your next read..."
            android:textSize="14sp"
            android:textColorHint="#9E9E9E"
            android:textColor="#1A1A1A"
            android:background="@null"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chipDiscovery"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="Discovery"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:paddingHorizontal="20dp"
                android:background="@drawable/bg_chip_selected" />

            <TextView
                android:id="@+id/chipFollows"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:layout_marginStart="16dp"
                android:text="Follows"
                android:textSize="13sp"
                android:textColor="#757575" />

            <TextView
                android:id="@+id/chipRomance"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:layout_marginStart="16dp"
                android:text="Romance"
                android:textSize="13sp"
                android:textColor="#757575" />
        </LinearLayout>

    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBooks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        tools:listitem="@layout/book_card" />

</LinearLayout>